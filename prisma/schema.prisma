generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum WithdrawalStatus {
  PENDING_VERIFICATION
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  CLOSED
}

enum MessageSender {
  USER
  ADMIN
}

enum TransactionType {
  Deposit
  Withdrawal
  Trade
  SubscriptionFee
  SubscriptionUpgrade    // NEW
  SubscriptionDowngrade  // NEW
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id                     String    @id @default(cuid())
  firstName              String?
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  password               String?
  image                  String?
  role                   Role      @default(USER)
  portfolioBalance       Float     @default(0)
  previousBalance        Float     @default(0)
  portfolioChangePercent Float     @default(0)
  realisedPnl            Float     @default(0)
  volatility             Float     @default(0)
  riskLabel              String    @default("Conservative")
  kycStatus              KycStatus @default(NONE)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  deposits        Deposit[]
  withdrawals     Withdrawal[]
  supportTickets  SupportTicket[]
  positions       Position[]
  notifications   Notification[]
  activityLogs    ActivityLog[]
  kycSubmission   KYCSubmission?
  transactions    Transaction[]
  subscriptions   Subscription[]
  tradingBots     TradingBot[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Finance ───────────────────────────────────────────────────────────────────

model DepositMethod {
  id        String   @id @default(cuid())
  label     String
  icon      String
  address   String
  network   String?
  note      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deposit {
  id          String            @id @default(cuid())
  userId      String
  amount      Float
  currency    String            @default("USD")
  status      TransactionStatus @default(PENDING)
  methodLabel String?
  note        String?
  adminNote   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Withdrawal {
  id        String           @id @default(cuid())
  userId    String
  amount    Float
  currency  String           @default("USD")
  status    WithdrawalStatus @default(PENDING)
  note      String?
  adminNote String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  description String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KYCSubmission {
  id           String    @id @default(cuid())
  userId       String    @unique
  status       String    @default("PENDING")
  documentType String    @default("PASSPORT")
  frontUrl     String?
  backUrl      String?
  selfieUrl    String?
  notes        String?
  submittedAt  DateTime  @default(now())
  reviewedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Support ───────────────────────────────────────────────────────────────────

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  sender    MessageSender
  body      String
  createdAt DateTime      @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model MarketPrice {
  id        String   @id @default(cuid())
  symbol    String   @unique
  geckoId   String   @unique
  name      String
  icon      String   @default("?")
  iconBg    String   @default("#cccccc")
  iconCol   String   @default("#ffffff")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Position {
  id         String    @id @default(cuid())
  userId     String
  asset      String
  symbol     String
  quantity   Float     @default(0)
  entryPrice Float     @default(0)
  currentPnl Float     @default(0)
  side       String    @default("LONG")
  status     String    @default("OPEN")
  leverage   Float     @default(1)
  marketType String    @default("CRYPTO")
  openedAt   DateTime  @default(now())
  closedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String            @id @default(cuid())
  type        TransactionType
  asset       String?
  amount      Float
  price       Float?
  action      String?
  leverage    Float?
  pnl         Float?
  status      TransactionStatus @default(PENDING)
  userId      String
  description String?             // NEW: human-readable note
  user        User                @relation(fields: [userId], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// ── Subscriptions ─────────────────────────────────────────────────────────────

model SubscriptionPlan {
  id                String   @id @default(cuid())
  name              String
  tier              String   @default("basic")
  description       String?
  price             Float
  minInvestment     Float    @default(0)
  weeklyReturnRate  Float    @default(0)
  interval          String   @default("WEEKLY")
  features          Json?
  isActive          Boolean  @default(true)
  highlight         String?
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions        Subscription[] @relation("ActivePlan")
  pendingSubscriptions Subscription[] @relation("PendingPlan")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  planId               String
  status               String    @default("active")
  startDate            DateTime
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  nextBillingDate      DateTime
  autoRenew            Boolean   @default(true)
  cancelledAt          DateTime?
  pendingPlanId        String?
  previousSubscriptionId String?

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan  @relation("ActivePlan", fields: [planId], references: [id])
  pendingPlan  SubscriptionPlan? @relation("PendingPlan", fields: [pendingPlanId], references: [id])

  @@index([userId, status])
  @@index([nextBillingDate, autoRenew, status])
}


model TradingBot {
  id        String    @id @default(cuid())
  userId    String
  name      String
  strategy  String    // "dca", etc.
  config    Json      // { symbol, baseAmount, interval }
  status    String    @default("stopped") // "running", "paused", "stopped"
  lastRun   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades BotTrade[]
}

model BotTrade {
  id         String   @id @default(cuid())
  botId      String
  symbol     String
  side       String   // "BUY" or "SELL"
  quantity   Float
  price      Float
  amount     Float
  executedAt DateTime @default(now())

  bot TradingBot @relation(fields: [botId], references: [id], onDelete: Cascade)
}
