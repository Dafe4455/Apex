generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  MODERATOR
  ANALYST
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum WithdrawalStatus {
  PENDING_VERIFICATION
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  CLOSED
}

enum MessageSender {
  USER
  ADMIN
}

enum TransactionType {
  Deposit
  Withdrawal
  Trade
  SubscriptionFee
  SubscriptionUpgrade
  SubscriptionDowngrade
}

enum RiskLabel {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
  SPECULATIVE
}

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
  LIQUIDATED
}

enum BotStatus {
  RUNNING
  PAUSED
  STOPPED
}

enum TradeSide {
  BUY
  SELL
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id                     String    @id @default(cuid())
  firstName              String?
  lastName               String?
  email                  String    @unique
  emailVerified          DateTime?
  password               String?
  image                  String?
  phone                  String?
  country                String?   // ISO-3166 alpha-2
  role                   Role      @default(USER)
  portfolioBalance       Decimal   @default(0) @db.Decimal(19, 8)
  previousBalance        Decimal   @default(0) @db.Decimal(19, 8)
  portfolioChangePercent Decimal   @default(0) @db.Decimal(19, 8)
  realisedPnl            Decimal   @default(0) @db.Decimal(19, 8)
  volatility             Decimal   @default(0) @db.Decimal(19, 8)
  riskLabel              RiskLabel @default(CONSERVATIVE)
  kycStatus              KycStatus @default(NONE)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  deposits        Deposit[]
  withdrawals     Withdrawal[]
  supportTickets  SupportTicket[]
  positions       Position[]
  notifications   Notification[]
  activityLogs    ActivityLog[]
  kycSubmission   KYCSubmission?
  transactions    Transaction[]
  subscriptions   Subscription[]
  tradingBots     TradingBot[]

  @@index([kycStatus, createdAt])
  @@index([role])
  @@index([country])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Finance ───────────────────────────────────────────────────────────────────

model DepositMethod {
  id        String   @id @default(cuid())
  label     String
  icon      String
  address   String
  network   String?
  note      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deposit {
  id          String            @id @default(cuid())
  userId      String
  amount      Decimal           @db.Decimal(19, 8)
  currency    String            @default("USD")
  status      TransactionStatus @default(PENDING)
  methodLabel String?
  note        String?
  adminNote   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Withdrawal {
  id        String           @id @default(cuid())
  userId    String
  amount    Decimal          @db.Decimal(19, 8)
  currency  String           @default("USD")
  status    WithdrawalStatus @default(PENDING)
  note      String?
  adminNote String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  description String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model KYCSubmission {
  id           String    @id @default(cuid())
  userId       String    @unique
  status       String    @default("PENDING")
  documentType String    @default("PASSPORT")
  frontUrl     String?
  backUrl      String?
  selfieUrl    String?
  notes        String?
  submittedAt  DateTime  @default(now())
  reviewedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Support ───────────────────────────────────────────────────────────────────

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  sender    MessageSender
  body      String
  createdAt DateTime      @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model MarketPrice {
  id        String   @id @default(cuid())
  symbol    String   @unique
  geckoId   String   @unique
  name      String
  icon      String   @default("?")
  iconBg    String   @default("#cccccc")
  iconCol   String   @default("#ffffff")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Position {
  id         String         @id @default(cuid())
  userId     String
  asset      String
  symbol     String
  quantity   Decimal        @default(0) @db.Decimal(19, 8)
  entryPrice Decimal        @default(0) @db.Decimal(19, 8)
  currentPnl Decimal        @default(0) @db.Decimal(19, 8)
  side       PositionSide   @default(LONG)
  status     PositionStatus @default(OPEN)
  leverage   Decimal        @default(1) @db.Decimal(5, 2)
  marketType String         @default("CRYPTO")
  openedAt   DateTime       @default(now())
  closedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([symbol, status])
}

model Transaction {
  id          String            @id @default(cuid())
  type        TransactionType
  asset       String?
  amount      Decimal           @db.Decimal(19, 8)
  price       Decimal?          @db.Decimal(19, 8)
  action      String?
  leverage    Decimal?          @db.Decimal(5, 2)
  pnl         Decimal?          @db.Decimal(19, 8)
  status      TransactionStatus @default(PENDING)
  userId      String
  description String?
  user        User              @relation(fields: [userId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId, createdAt])
  @@index([type, status])
}

// ── Subscriptions ─────────────────────────────────────────────────────────────

model SubscriptionPlan {
model SubscriptionPlan {
  id               String   @id @default(cuid())
  name             String
  description      String?
  price            Float
  interval         String
  features         Json?
  isActive         Boolean  @default(true)
  tier             String?
  minInvestment    Float?
  weeklyReturnRate Float?
  sortOrder        Int      @default(0)
  highlight        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Match the named relations from Subscription model
  subscriptions  Subscription[] @relation("ActivePlan")
  pendingSubs    Subscription[] @relation("PendingPlan")
}


model Subscription {
  id                 String   @id @default(cuid())
  userId             String
  planId             String
  pendingPlanId      String?
  status             String
  startDate          DateTime
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime
  autoRenew          Boolean  @default(true)
  cancelledAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan  @relation("ActivePlan", fields: [planId], references: [id])
  pendingPlan SubscriptionPlan? @relation("PendingPlan", fields: [pendingPlanId], references: [id])

  @@unique([userId, planId])
}


// ── Trading Bots ──────────────────────────────────────────────────────────────

model TradingBot {
  id        String    @id @default(cuid())
  userId    String
  name      String
  strategy  String    // "dca", "grid", "momentum", etc.
  config    Json      // { symbol, baseAmount, interval }
  status    BotStatus @default(STOPPED)
  lastRun   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades BotTrade[]

  @@index([userId, status])
  @@index([status, lastRun])
}

model BotTrade {
  id         String   @id @default(cuid())
  botId      String
  symbol     String
  side       TradeSide
  quantity   Decimal  @db.Decimal(19, 8)
  price      Decimal  @db.Decimal(19, 8)
  amount     Decimal  @db.Decimal(19, 8)
  executedAt DateTime @default(now())

  bot TradingBot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, executedAt])
  @@index([symbol, executedAt])
}
